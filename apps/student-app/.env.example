# StudentApp Environment Variables
# Copy this file to .env and update with your values

# Django Backend API URL
# For iOS Simulator
EXPO_PUBLIC_API_URL=https://api.crmai.uz/api/v1

# For Android Emulator (uncomment and use this instead)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8008/api/v1

# For Physical Device (use your computer's local IP)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8008/api/v1

# For production, use your actual API URL:
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
