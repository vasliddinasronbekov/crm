# ============================================================================
# STUDENT APP V2 - Environment Configuration
# ============================================================================

# ===== API CONFIGURATION =====
# Backend API base URL
EXPO_PUBLIC_API_URL=https://api.crmai.uz

# WebSocket base URL
EXPO_PUBLIC_WS_URL=ws://api.crmai.uz

# API Timeout (milliseconds)
EXPO_PUBLIC_API_TIMEOUT=30000

# ===== FEATURE FLAGS =====
# Enable/disable features for testing or gradual rollout

# Gamification features
EXPO_PUBLIC_ENABLE_GAMIFICATION=true

# Social learning features
EXPO_PUBLIC_ENABLE_SOCIAL=true

# AI voice assistant
EXPO_PUBLIC_ENABLE_AI_VOICE=true

# Real-time chat
EXPO_PUBLIC_ENABLE_CHAT=true

# Shop and coins system
EXPO_PUBLIC_ENABLE_SHOP=true

# Offline mode
EXPO_PUBLIC_ENABLE_OFFLINE=true

# ===== EXTERNAL SERVICES =====
# Analytics
EXPO_PUBLIC_MIXPANEL_TOKEN=

# Error tracking
EXPO_PUBLIC_SENTRY_DSN=

# Push notifications
EXPO_PUBLIC_ONESIGNAL_APP_ID=

# ===== APP CONFIGURATION =====
# Default language (en, uz, ru, tr)
EXPO_PUBLIC_DEFAULT_LANGUAGE=en

# App version
EXPO_PUBLIC_APP_VERSION=2.0.0

# Environment (development, staging, production)
EXPO_PUBLIC_ENV=development

# Debug mode
EXPO_PUBLIC_DEBUG=true

# ===== MEDIA CONFIGURATION =====
# Maximum file upload size (MB)
EXPO_PUBLIC_MAX_FILE_SIZE=10

# Supported file types for uploads
EXPO_PUBLIC_ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png

# ===== CACHE CONFIGURATION =====
# Cache duration for API responses (milliseconds)
EXPO_PUBLIC_CACHE_DURATION=300000

# ===== WEBSOCKET CONFIGURATION =====
# WebSocket reconnection attempts
EXPO_PUBLIC_WS_RECONNECT_ATTEMPTS=5

# WebSocket reconnection delay (milliseconds)
EXPO_PUBLIC_WS_RECONNECT_DELAY=3000

# ===== PERFORMANCE =====
# Enable React Query devtools
EXPO_PUBLIC_ENABLE_RQ_DEVTOOLS=true

# Enable performance monitoring
EXPO_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false
