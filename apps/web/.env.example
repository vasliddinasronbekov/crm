# API Configuration
NEXT_PUBLIC_API_URL=https://api.crmai.uz/api

# Environment
NODE_ENV=development

# App Configuration
NEXT_PUBLIC_APP_NAME="EduVoice Admin"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Features Flags (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CRM=true
NEXT_PUBLIC_ENABLE_LMS=true
NEXT_PUBLIC_ENABLE_MESSAGING=true

# Production API URL (uncomment for production)
# NEXT_PUBLIC_API_URL=https://api.eduvoice.com/api/
