# ==============================================
# EduVoice Platform Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# ==============================================

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/dbname

# Redis (for Celery and caching)
REDIS_URL=redis://localhost:6379/1

# ==============================================
# Email Configuration (SendGrid)
# ==============================================
# Sign up at: https://sendgrid.com/
# Get API key from: Settings -> API Keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_FROM_NAME=EduVoice Platform

# ==============================================
# Video Services
# ==============================================
# YouTube Data API v3
# Get from: https://console.cloud.google.com/
# Enable YouTube Data API v3, then create credentials
YOUTUBE_API_KEY=your-youtube-api-key-here

# ==============================================
# Storage (for file uploads)
# ==============================================
# Local storage (default)
MEDIA_ROOT=media/
MEDIA_URL=/media/

# AWS S3 (optional)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# ==============================================
# Firebase Cloud Messaging (for push notifications)
# ==============================================
# Get from Firebase Console -> Project Settings -> Service Accounts
FIREBASE_CREDENTIALS_PATH=path/to/firebase-adminsdk.json
# Or use environment variable:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# ==============================================
# Payment Gateways - Subscription System
# ==============================================

# STRIPE (International Card Payments)
# Sign up at: https://dashboard.stripe.com/register
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Get webhook secret: https://dashboard.stripe.com/test/webhooks
STRIPE_SECRET_KEY=sk_test_51ABC123_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_51ABC123_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PAYME (Uzbekistan Payment Gateway)
# Sign up at: https://payme.uz/
# Documentation: https://developer.help.paycom.uz/
PAYME_MERCHANT_ID=your-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key

# CLICK (Uzbekistan Payment Gateway)
# Sign up at: https://click.uz/
# Documentation: https://docs.click.uz/
CLICK_MERCHANT_ID=your-merchant-id
CLICK_SERVICE_ID=your-service-id
CLICK_SECRET_KEY=your-secret-key

# ==============================================
# SMS Service (Eskiz.uz)
# ==============================================
ESKIZ_EMAIL=your-email@example.com
ESKIZ_PASSWORD=your-password
ESKIZ_FROM=your-sender-name

# ==============================================
# Security
# ==============================================
# CORS Origins (frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Session & Cookie Security
SESSION_COOKIE_SECURE=False  # Set to True in production with HTTPS
CSRF_COOKIE_SECURE=False     # Set to True in production with HTTPS

# ==============================================
# Celery (Background Tasks)
# ==============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==============================================
# Logging
# ==============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==============================================
# Development Settings
# ==============================================
# Set to False in production
ENABLE_DEBUG_TOOLBAR=True
